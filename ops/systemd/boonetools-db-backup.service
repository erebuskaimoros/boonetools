[Unit]
Description=BooneTools Postgres Backup
After=docker.service
Wants=docker.service

[Service]
Type=oneshot
User=root
EnvironmentFile=/opt/boonetools-backend/backend/.env
ExecStart=/opt/boonetools-backend/scripts/boonetools-db-backup.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=boonetools-db-backup
