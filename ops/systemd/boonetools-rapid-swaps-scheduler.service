[Unit]
Description=BooneTools Rapid Swaps Scheduler
After=network-online.target docker.service boonetools-api.service
Wants=network-online.target docker.service

[Service]
Type=oneshot
User=deploy
WorkingDirectory=/opt/boonetools-backend/backend
Environment=NODE_ENV=production
EnvironmentFile=/opt/boonetools-backend/backend/.env
ExecStart=/usr/bin/node src/run-job.js rapid-swaps-scheduler
StandardOutput=journal
StandardError=journal
SyslogIdentifier=boonetools-rapid-swaps-scheduler
